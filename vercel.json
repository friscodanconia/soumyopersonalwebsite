{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "soumyosinha.com" }],
      "destination": "https://www.soumyosinha.com/:path",
      "permanent": true
    },
    {
      "source": "/",
      "has": [{ "type": "host", "value": "howindiaeats.soumyosinha.com" }],
      "destination": "/projects/searching-for-food/guide",
      "permanent": false
    },
    {
      "source": "/ai-updates",
      "destination": "https://aiupdates.soumyosinha.com",
      "permanent": false
    },
    {
      "source": "/ai-updates/:path*",
      "destination": "https://aiupdates.soumyosinha.com/:path*",
      "permanent": false
    }
  ],
  "trailingSlash": false,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
